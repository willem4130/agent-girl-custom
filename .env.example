# =============================================================================
# Anthropic Configuration (Claude Models)
# =============================================================================
# Get your API key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-key-here

# =============================================================================
# Z.AI Configuration (GLM Models)
# =============================================================================
# Get your API key from: https://z.ai
# The server automatically configures the endpoint when you select a GLM model
ZAI_API_KEY=your-zai-key-here

# =============================================================================
# Moonshot AI Configuration (Kimi K2 Models)
# =============================================================================
# Get your API key from: https://platform.moonshot.ai/
# The server automatically configures the endpoint when you select a Kimi model
MOONSHOT_API_KEY=your-moonshot-key-here

# =============================================================================
# RapidAPI Configuration (Social Media Scrapers for Copywriting Mode)
# =============================================================================
# Get your API key from: https://rapidapi.com/
# Required for Instagram, Facebook, and LinkedIn scraping in Copywriting Mode
# Free tier available with limited requests
RAPIDAPI_KEY=your-rapidapi-key-here

# =============================================================================
# Media Generation Configuration
# =============================================================================
# Kie.ai API Key for image generation (Seedream 4.5, Nano Banana)
# Get your API key from: https://kie.ai/
# Costs: Seedream ~$0.02/image, Nano Banana ~$0.05-0.10/image
KIE_API_KEY=your-kie-api-key-here

# FAL.ai API Key for video generation (Kling, Wan, Veo)
# Get your API key from: https://fal.ai/
# Costs: Kling ~$0.25-0.50 per 5s video
FAL_API_KEY=your-fal-api-key-here

# Optional: Local media storage path (defaults to ./data/media)
# MEDIA_STORAGE_PATH=/path/to/media/storage

# Optional: CDN URL for serving media files (if using external CDN)
# MEDIA_CDN_URL=https://cdn.example.com
